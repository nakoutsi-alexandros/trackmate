# Anthropic API Key - από το console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Sheets ID - από το URL του sheet σου
# π.χ. https://docs.google.com/spreadsheets/d/ΑΥΤΟ_ΕΔΩ/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Service Account credentials (JSON σε base64)
GOOGLE_SERVICE_ACCOUNT_KEY=your_base64_encoded_service_account_json
